#!/bin/sh
# Wrapper for PSScriptAnalyzer — accepts one or more PowerShell file paths.
# Called by pre-commit with all staged .ps1/.psm1/.psd1 files as arguments.
# PowerShell is installed as a local dotnet tool in the user's $HOME-scoped
# manifest (see lib/common.sh install_pwsh) and invoked via `dotnet pwsh`,
# per ai/global/dotnet.instructions.md (always `dotnet <toolname>`, never add
# the tool to PATH). dotnet only resolves a local tool manifest by walking up
# from its own cwd, so we cd to $HOME before invoking it and must resolve
# staged file paths to absolute first.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

command -v dotnet > /dev/null 2>&1 || die "dotnet is not installed — required to run PowerShell (dotnet pwsh)"

(cd "$HOME" && dotnet tool list 2>/dev/null | awk 'tolower($3)=="pwsh"{found=1} END{exit !found}') \
    || die "PowerShell is not installed as a local dotnet tool — run ./install-deps-arch or ./install-deps-debian"

FAILED=0
for f in "$@"; do
    abs_f="$(cd "$(dirname "$f")" && pwd)/$(basename "$f")"
    (cd "$HOME" && dotnet pwsh -NoProfile -NonInteractive -Command "
        Import-Module PSScriptAnalyzer -ErrorAction Stop
        \$r = Invoke-ScriptAnalyzer -Path '$abs_f' -Severity Error,Warning
        if (\$r) { \$r | Format-Table -AutoSize; exit 1 }
    ") || { printf '\n\033[31m✗\033[0m %s\n' "PSScriptAnalyzer failed: $f" >&2; FAILED=1; }
done
[ "$FAILED" -eq 0 ] || die "PSScriptAnalyzer failed on one or more files"
