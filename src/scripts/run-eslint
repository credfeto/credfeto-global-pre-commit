#!/bin/sh
# Wrapper for eslint — skips silently if no package.json or no eslint config.
REPO_ROOT=$(git rev-parse --show-toplevel)
[ -f "$REPO_ROOT/package.json" ] || exit 0
for cfg in .eslintrc .eslintrc.js .eslintrc.cjs .eslintrc.json .eslintrc.yml \
           .eslintrc.yaml eslint.config.js eslint.config.mjs eslint.config.cjs; do
    [ -f "$REPO_ROOT/$cfg" ] && exec eslint "$@"
done
exit 0
