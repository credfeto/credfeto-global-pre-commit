#! /bin/sh
# Prints, one per line, the --filter-not-namespace values buildtest should pass to
# `dotnet test` to skip benchmark test projects that the staged change set cannot
# affect, plus integration tests (always safe to skip in pre-commit).
#
# Usage: benchmark-test-filter <solution-dir>
#
# A benchmark test project (name contains "bench", ends ".Test[s]") is considered
# affected — and therefore not skipped — when a staged .NET-relevant file falls
# under its own directory or the directory of any project it references, directly
# or transitively (via <ProjectReference>). Any staged change to a solution-wide
# shared build input (Directory.Build.props/targets, Directory.Packages.props,
# global.json, or a *.props/*.targets/*.globalconfig/*.ruleset/*.sln/*.slnx file
# directly in the solution directory) is treated as affecting every benchmark.
# When nothing is staged (e.g. a manual run), no benchmark is skipped.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

SOLUTION_DIR="$1"
[ -n "$SOLUTION_DIR" ] || die "usage: benchmark-test-filter <solution-dir>"
[ -d "$SOLUTION_DIR" ] || die "not a directory: $SOLUTION_DIR"
SOLUTION_DIR=$(readlink -f "$SOLUTION_DIR")

# Integration tests are always safe to skip in pre-commit.
printf '*.Integration.Tests\n*.Integration.Tests.*\n'

REPO_ROOT=$(git -C "$SOLUTION_DIR" rev-parse --show-toplevel 2>/dev/null)
[ -n "$REPO_ROOT" ] || exit 0

ALL_CSPROJ=$(find "$SOLUTION_DIR" -type f -iname "*.csproj" -not -path "*/obj/*" -not -path "*/bin/*")
BENCH_PROJECTS=""
while IFS= read -r proj; do
    [ -n "$proj" ] || continue
    bn=$(basename "$proj")
    if printf '%s\n' "$bn" | grep -qi "bench" && printf '%s\n' "$bn" | grep -qiE '\.tests?\.csproj$'; then
        BENCH_PROJECTS="$BENCH_PROJECTS
$proj"
    fi
done <<CSPROJ_EOF
$ALL_CSPROJ
CSPROJ_EOF
[ -n "$BENCH_PROJECTS" ] || exit 0

# Only staged changes count — a manual run with nothing staged runs every benchmark.
CHANGED_RELATIVE=$(git -C "$REPO_ROOT" diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '\.(cs|csproj|sln|slnx|props|targets|globalconfig|ruleset)$')
[ -n "$CHANGED_RELATIVE" ] || exit 0

CHANGED_ABS=""
while IFS= read -r f; do
    [ -n "$f" ] || continue
    CHANGED_ABS="$CHANGED_ABS
$REPO_ROOT/$f"
done <<CHANGED_EOF
$CHANGED_RELATIVE
CHANGED_EOF

# A change to a solution-wide shared build input could affect every benchmark.
GLOBAL_TOUCHED=$(printf '%s\n' "$CHANGED_ABS" \
    | grep -E '(^|/)(Directory\.Build\.(props|targets)|Directory\.Packages\.props|global\.json)$')
if [ -z "$GLOBAL_TOUCHED" ]; then
    while IFS= read -r f; do
        [ -n "$f" ] || continue
        case "$f" in
            "$SOLUTION_DIR"/*.props | "$SOLUTION_DIR"/*.targets | "$SOLUTION_DIR"/*.globalconfig | "$SOLUTION_DIR"/*.ruleset | "$SOLUTION_DIR"/*.sln | "$SOLUTION_DIR"/*.slnx)
                [ "$(dirname "$f")" = "$SOLUTION_DIR" ] && GLOBAL_TOUCHED="$f"
                ;;
        esac
    done <<GLOBAL_EOF
$CHANGED_ABS
GLOBAL_EOF
fi
[ -z "$GLOBAL_TOUCHED" ] || exit 0

EDGES_FILE=$(mktemp "${TMPDIR:-/tmp}/benchmark-test-filter.XXXXXXXXXX") || die "mktemp failed"
trap 'rm -f "$EDGES_FILE"' EXIT

while IFS= read -r proj; do
    [ -f "$proj" ] || continue
    proj_dir=$(dirname "$proj")
    grep -o 'ProjectReference[[:space:]]*Include[[:space:]]*=[[:space:]]*"[^"]*"' "$proj" 2>/dev/null \
        | sed 's/.*"\(.*\)"$/\1/' \
        | while IFS= read -r ref; do
            [ -n "$ref" ] || continue
            ref_native=$(printf '%s' "$ref" | tr '\134' '/')
            ref_abs=$(readlink -f "$proj_dir/$ref_native" 2>/dev/null)
            [ -n "$ref_abs" ] && [ -f "$ref_abs" ] && printf '%s|%s\n' "$proj" "$ref_abs" >> "$EDGES_FILE"
        done
done <<PROJECTS_EOF
$ALL_CSPROJ
PROJECTS_EOF

# Prints the transitive closure of csproj paths reachable from $1 via ProjectReference.
resolve_reachable() {
    awk -v start="$1" -F'|' '
        { adj[$1] = adj[$1] $2 "\n" }
        END {
            queue[0] = start; n = 1; head = 0
            visited[start] = 1
            while (head < n) {
                cur = queue[head]; head++
                split(adj[cur], refs, "\n")
                for (i in refs) {
                    r = refs[i]
                    if (r == "") continue
                    if (!(r in visited)) {
                        visited[r] = 1
                        queue[n] = r
                        n++
                    }
                }
            }
            for (v in visited) print v
        }
    ' "$EDGES_FILE"
}

SKIP_LIST=""
while IFS= read -r bench; do
    [ -n "$bench" ] || continue
    REACHABLE_DIRS=$(resolve_reachable "$bench" | while IFS= read -r p; do
        [ -n "$p" ] && dirname "$p"
    done | sort -u)

    AFFECTED=0
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        printf '%s\n' "$CHANGED_ABS" | grep -qF "$d/" && AFFECTED=1
    done <<DIRS_EOF
$REACHABLE_DIRS
DIRS_EOF

    if [ "$AFFECTED" -eq 0 ]; then
        ns=$(basename "$bench" .csproj)
        SKIP_LIST="$SKIP_LIST
$ns"
    fi
done <<BENCH_EOF
$BENCH_PROJECTS
BENCH_EOF

while IFS= read -r ns; do
    [ -n "$ns" ] || continue
    printf '*.%s\n*.%s.*\n' "$ns" "$ns"
done <<SKIP_EOF
$SKIP_LIST
SKIP_EOF
