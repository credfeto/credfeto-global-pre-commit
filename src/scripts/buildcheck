#! /bin/sh
# Sourced from https://github.com/credfeto/scripts/blob/main/development/buildcheck

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by subprocesses (e.g. git hooks).
# Source: https://docs.anthropic.com/en/docs/claude-code/settings#environment-variables
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

# Returns 0 if $1 (command name) and $2 (package ID) match the same row in local or global dotnet tool list.
dotnet_tool_installed() {
    dotnet tool list 2>/dev/null \
        | awk -v cmd="$1" -v pkg="$2" \
            'tolower($3)==tolower(cmd) && tolower($1)==tolower(pkg){found=1} END{exit !found}' \
        && return 0
    dotnet tool list --global 2>/dev/null \
        | awk -v cmd="$1" -v pkg="$2" \
            'tolower($3)==tolower(cmd) && tolower($1)==tolower(pkg){found=1} END{exit !found}' \
        && return 0
    return 1
}

require_dotnet_tool() {
    dotnet_tool_installed "$1" "$2" && return 0
    if is_ai_agent; then
        _repo=$(git rev-parse --show-toplevel 2>/dev/null)
        if [ -n "$_repo" ] && { [ -f "$_repo/.config/dotnet-tools.json" ] || [ -f "$_repo/dotnet-tools.json" ]; }; then
            die "dotnet-tools.json exists in this repository but $2 ($1) is not installed — add $2 to the manifest and run 'dotnet tool restore'. Do not install it directly."
        fi
        die "Required package ($2) is not installed so cannot run $1.  Operator needs to provide this to the environment.  Do not install it yourself"
    fi
    die "$1 dotnet tool is not installed"
}

require_dotnet_tool buildcheck FunFair.BuildCheck

SOLUTION=$(find "$PWD" -type f -iname "*.sln" | head -1)
[ -z "$SOLUTION" ] && SOLUTION=$(find "$PWD" -type f -iname "*.slnx" | head -1)
[ -z "$SOLUTION" ] && { info "No solution file found — skipping"; exit 0; }

dotnet buildcheck -Solution "$SOLUTION" -WarningAsErrors true -PreReleaseBuild true || die "Check failed"
