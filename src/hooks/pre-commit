#!/bin/sh
# Global pre-commit orchestrator.
# Installed via: git config --global core.hooksPath /path/to/hooks

REPO_ROOT=$(git rev-parse --show-toplevel)
SCRIPTS_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"
# HOOKS_REPO_DIR_TEST_OVERRIDE is a test-only escape hatch; never set this variable in production shells.
HOOKS_REPO_DIR="${HOOKS_REPO_DIR_TEST_OVERRIDE:-$(cd "$(dirname "$0")/../.." && pwd)}"

# Ensure language: system wrappers invoked by bare name (e.g. run-bats,
# run-eslint, run-stylelint, run-psscriptanalyzer) resolve to the versions
# shipped alongside this hook, independent of the install script's PATH
# symlinks or any consumer's container ENV/profile setup.
PATH="$SCRIPTS_DIR:$PATH"
export PATH

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by git and therefore by this hook.
# Source: https://code.claude.com/docs/en/env-vars
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

# Returns true (0) when running inside any OCI container (Docker, Podman, etc.).
# Docker:  creates /.dockerenv
# Podman:  creates /run/.containerenv and sets container=podman in the environment
# systemd-nspawn: sets container=systemd-nspawn in the environment
# k8s/containerd: visible in /proc/1/cgroup
is_container() {
    [ -f /.dockerenv ] \
        || [ -f /run/.containerenv ] \
        || [ -n "${container:-}" ] \
        || grep -q 'docker\|containerd\|kubepods' /proc/1/cgroup 2>/dev/null
}

has_cmd() { command -v "$1" > /dev/null 2>&1; }

# Mark the active PR and issue as blocked.  No-ops silently when gh is absent,
# no PR exists for the branch, or any gh command fails.
mark_blocked() {
    has_cmd gh || return 0
    _MB_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
    [ -n "$_MB_BRANCH" ] || return 0
    GH_PROMPT_DISABLED=1 gh label create "blocked" --color "B60205" --description "Blocked by an external dependency" --force > /dev/null 2>&1 || true
    _MB_PR=$(GH_PROMPT_DISABLED=1 gh pr list --head "$_MB_BRANCH" --json number --jq '.[0].number' 2>/dev/null || true)
    if [ -n "$_MB_PR" ] && [ "$_MB_PR" != "null" ]; then
        GH_PROMPT_DISABLED=1 gh pr edit "$_MB_PR" --add-label "blocked" > /dev/null 2>&1 || true
    fi
    _MB_ISSUE=$(printf '%s' "$_MB_BRANCH" | grep -oE '/[0-9]+' | head -1 | tr -d '/')
    if [ -n "$_MB_ISSUE" ]; then
        GH_PROMPT_DISABLED=1 gh issue edit "$_MB_ISSUE" --add-label "blocked" > /dev/null 2>&1 || true
    fi
}

# Die with a message, marking the active PR/issue as blocked first when run as
# an AI agent.  Use instead of die for environment/tool problems the agent
# cannot fix itself.
die_blocked() {
    if is_ai_agent; then
        mark_blocked
        die "$* — ask the user to resolve this before continuing"
    else
        die "$*"
    fi
}

# Returns 0 if $1 (command name) and $2 (package ID) match the same row in local or global dotnet tool list.
dotnet_tool_installed() {
    dotnet tool list 2>/dev/null \
        | awk -v cmd="$1" -v pkg="$2" \
            'tolower($3)==tolower(cmd) && tolower($1)==tolower(pkg){found=1} END{exit !found}' \
        && return 0
    dotnet tool list --global 2>/dev/null \
        | awk -v cmd="$1" -v pkg="$2" \
            'tolower($3)==tolower(cmd) && tolower($1)==tolower(pkg){found=1} END{exit !found}' \
        && return 0
    return 1
}

# Protected in ALL repos: linter/style/shared config that defines conformance
# rules and must not be modified or removed to silence a check — fix the
# underlying issue instead. One filename (or glob) per case arm so it is
# possible to tell by eye whether $1 matches (see issue #186; no regex).
# Path-scoped entries (a specific directory, not just a filename) are matched
# against the full staged path; everything else is matched against the
# basename only.
is_protected_everywhere_file() {
    case "$1" in
        .clj-kondo/config.edn | */.clj-kondo/config.edn) return 0 ;;
        ai/global/*.md) return 0 ;;
        .github/linters/?*) return 0 ;;
    esac
    case "${1##*/}" in
        .shellcheckrc) return 0 ;;
        .checkov.yaml) return 0 ;;
        .clang-format) return 0 ;;
        .editorconfig) return 0 ;;
        .csharpierrc) return 0 ;;
        .ansible-lint | .ansible-lint.yml) return 0 ;;
        .arm-ttk.psd1) return 0 ;;
        .cfnlintrc.yml) return 0 ;;
        .coffee-lint.json) return 0 ;;
        .stylelintrc.json) return 0 ;;
        .hadolint.yml | .hadolint.yaml) return 0 ;;
        .editorconfig-checker.json) return 0 ;;
        actionlint.yml) return 0 ;;
        zizmor.yaml) return 0 ;;
        .gitleaks.toml) return 0 ;;
        .golangci.yml) return 0 ;;
        .groovylintrc.json) return 0 ;;
        .htmlhintrc) return 0 ;;
        sun_checks.xml | google_checks.xml) return 0 ;;
        eslint.config.mjs) return 0 ;;
        .jscpd.json) return 0 ;;
        .chktexrc) return 0 ;;
        .luacheckrc) return 0 ;;
        .markdown-lint.yml) return 0 ;;
        .openapirc.yml) return 0 ;;
        php.ini) return 0 ;;
        phpcs.xml) return 0 ;;
        phpstan.neon) return 0 ;;
        psalm.xml) return 0 ;;
        .powershell-psscriptanalyzer.psd1) return 0 ;;
        .protolintrc.yml) return 0 ;;
        .python-black) return 0 ;;
        .flake8) return 0 ;;
        .isort.cfg) return 0 ;;
        .mypy.ini) return 0 ;;
        .python-lint) return 0 ;;
        .ruff.toml) return 0 ;;
        .lintr) return 0 ;;
        .ruby-lint.yml) return 0 ;;
        .scalafmt.conf) return 0 ;;
        .snakefmt.toml) return 0 ;;
        .codespellrc) return 0 ;;
        .tflint.hcl) return 0 ;;
        trivy.yaml) return 0 ;;
        .textlintrc) return 0 ;;
        .yaml-lint.yml) return 0 ;;
        pre-release.rule-settings.json) return 0 ;;
        release.rule-settings.json) return 0 ;;
        .markdownlintignore) return 0 ;;
        .eslintignore) return 0 ;;
        .stylelintignore) return 0 ;;
        .sqlfluffignore) return 0 ;;
        .ansible-lint-ignore) return 0 ;;
        .prettierignore) return 0 ;;
        # -- moved here from the hooks-repo-only guard below: same gap as
        # .globalconfig (issue #186) -- protected in every repo, not just this one.
        .globalconfig) return 0 ;;
        global.json) return 0 ;;
        .sqlfluff*) return 0 ;;
        .tsqllint*) return 0 ;;
        .ai-instructions) return 0 ;;
        Directory.Build.props) return 0 ;;
        .*lint*) return 0 ;;
    esac
    return 1
}

# Protected only inside this hooks repo's own checkout — this repo's own
# ai/local/*.md instruction files must not be casually edited. ai/local/*.md
# in OTHER repos is intentionally NOT protected: committing to it is how the
# cross-repo AI-memory workflow (.ai-instructions) records what was learned.
is_protected_hooks_repo_file() {
    case "$1" in
        ai/local/*.md) return 0 ;;
    esac
    return 1
}

# ── Mode selection ────────────────────────────────────────────────────────────
# Default MODE=commit reproduces today's staged-only, abort-on-empty behaviour
# completely unchanged. MODE=all-files is an explicit baseline/CI mode
# (invoked as `pre-commit --all-files`): it runs every category check against
# the full tracked tree (git ls-files) regardless of what is staged, and skips
# the guards that only make sense mid-commit (empty-stage abort, branch check,
# identity check, merge-commit guard).
MODE=commit
case "${1:-}" in
    "") ;;
    --all-files) MODE=all-files ;;
    *) die "unknown argument: $1 (supported: --all-files)" ;;
esac

# Abort immediately if nothing is staged — prevents accidental empty commits.
# Skipped in all-files mode, which is expected to run against a clean tree.
ALL_STAGED=$(git diff --cached --name-only)
if [ "$MODE" = "commit" ]; then
    [ -z "$ALL_STAGED" ] && die "nothing is staged — commit would be empty"
fi

# Block staged additions, changes, OR deletions of linter/style config files in
# ALL repos.  These files define conformance rules and must not be modified or
# removed to silence linter errors — fix the underlying issue instead.
# Checked here, before the STAGED early-exit, so that a commit consisting solely
# of a deletion of a protected file is also caught. See is_protected_everywhere_file
# above for the actual list of protected files (issue #186).
LINTER_CONFIG_CHANGES=""
while IFS= read -r f; do
    [ -n "$f" ] || continue
    is_protected_everywhere_file "$f" && LINTER_CONFIG_CHANGES="${LINTER_CONFIG_CHANGES}${f}
"
done <<EOF
$ALL_STAGED
EOF
if [ -n "$LINTER_CONFIG_CHANGES" ]; then
    printf '\n\033[31m✗\033[0m %s\n' "Linter/style config files cannot be added, changed, or deleted:" >&2
    printf '%s' "$LINTER_CONFIG_CHANGES" | sed 's/^/  /' | sort -u >&2
    die "remove linter config file changes from this commit"
fi

# Only look at staged files that are being added/copied/modified.
# Skipped in all-files mode — an empty stage does not mean "nothing to check".
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ "$MODE" = "commit" ]; then
    [ -z "$STAGED" ] && exit 0
fi

cd "$REPO_ROOT" || die "cannot cd to repo root"

# CHECK_FILES is the file-list category checks below key off: staged files in
# commit mode (unchanged), or every tracked file in all-files mode.
if [ "$MODE" = "all-files" ]; then
    CHECK_FILES=$(git ls-files)
else
    CHECK_FILES="$STAGED"
fi

# ── dotnet-tools.json sanity ─────────────────────────────────────────────────
# A dotnet-tools.json anywhere in the repo pins local tool versions and
# breaks the expected global tool setup.
DOTNET_TOOLS_FILES=$(find "$REPO_ROOT" -name "dotnet-tools.json" -not -path "*/.git/*" 2>/dev/null)
if [ -n "$DOTNET_TOOLS_FILES" ]; then
    printf '\n\033[31m✗\033[0m %s\n' "Corrupt environment: dotnet-tools.json found in repo — it pins local tool versions and breaks the expected tool setup." >&2
    printf '%s\n' "$DOTNET_TOOLS_FILES" | sed 's/^/  /' >&2
    die "delete the dotnet-tools.json file(s) listed above and retry"
fi

# Block staged changes to files that must stay editable only in this hooks
# repo's own checkout. See is_protected_hooks_repo_file above for the actual
# list (issue #186 moved most of what used to be here into
# is_protected_everywhere_file, since it was protected only in the hooks
# repo purely by omission, not by design).
if [ "$REPO_ROOT" = "$HOOKS_REPO_DIR" ]; then
    PROTECTED_CHANGES=""
    while IFS= read -r f; do
        [ -n "$f" ] || continue
        is_protected_hooks_repo_file "$f" && PROTECTED_CHANGES="${PROTECTED_CHANGES}${f}
"
    done <<EOF
$ALL_STAGED
EOF
    if [ -n "$PROTECTED_CHANGES" ]; then
        printf '\n\033[31m✗\033[0m %s\n' "Protected files cannot be added or changed:" >&2
        printf '%s' "$PROTECTED_CHANGES" | sed 's/^/  /' | sort -u >&2
        die "remove protected file changes from this commit"
    fi
fi

# ── Template-only files: block .ai-instructions and ai/global/ in non-template repos ──
# NOTE: is_protected_everywhere_file() above now also unconditionally blocks
# .ai-instructions and ai/global/*.md in EVERY repo, including the 3 exempted
# below (issue #186 follow-up) — so this exemption no longer has any effect
# for those two patterns; it remains meaningful only for a hypothetical
# non-.md file under ai/global/.
# .ai-instructions and ai/global/ may only be changed in cs-template,
# funfair-server-template, or funfair-treasury-reporting.
if [ "$REPO_ROOT" != "$HOOKS_REPO_DIR" ]; then
    _REPO_NAME=$(git remote get-url origin 2>/dev/null \
        | sed 's|.*[/:]||; s|\.git$||' \
        | tr -d '[:space:]' || true)
    case "$_REPO_NAME" in
        cs-template|funfair-server-template|funfair-treasury-reporting)
            ;;
        *)
            TEMPLATE_ONLY_CHANGES=$(printf '%s\n' "$ALL_STAGED" \
                | grep -E '(^|/)\.ai-instructions$|^ai/global/' || true)
            if [ -n "$TEMPLATE_ONLY_CHANGES" ]; then
                printf '\n\033[31m✗\033[0m %s\n' "Template-only files cannot be changed in this repository:" >&2
                printf '%s\n' "$TEMPLATE_ONLY_CHANGES" | sed 's/^/  /' | sort -u >&2
                die ".ai-instructions and ai/global/ may only be changed in cs-template, funfair-server-template, or funfair-treasury-reporting"
            fi
            ;;
    esac
fi

# ── .NET install-location sanity ─────────────────────────────────────────────
# A per-user dotnet at $HOME/.dotnet shadows the system binary and causes
# build/test inconsistencies.  The only valid install is /usr/share/dotnet/dotnet.
if [ -f "$HOME/.dotnet/dotnet" ]; then
    die "Corrupt environment: dotnet found at \$HOME/.dotnet/dotnet — remove it; the canonical install is /usr/share/dotnet/dotnet"
fi
if has_cmd dotnet; then
    _DOTNET_BIN=$(command -v dotnet)
    _DOTNET_REAL=$(readlink -f "$_DOTNET_BIN" 2>/dev/null || echo "$_DOTNET_BIN")
    if [ "$_DOTNET_REAL" != "/usr/share/dotnet/dotnet" ]; then
        die "Corrupt environment: dotnet resolves to ${_DOTNET_REAL} but must be at /usr/share/dotnet/dotnet"
    fi
fi

# Pre-compute tool availability once.
if has_cmd dotnet;     then HAS_DOTNET=1;    else HAS_DOTNET=0;    fi
if has_cmd npm;        then HAS_NPM=1;       else HAS_NPM=0;       fi
if has_cmd pre-commit; then HAS_PRECOMMIT=1; else HAS_PRECOMMIT=0; fi
if has_cmd sqlfluff;   then HAS_SQLFLUFF=1;  else HAS_SQLFLUFF=0;  fi
if has_cmd cfn-lint;   then HAS_CFNLINT=1;   else HAS_CFNLINT=0;   fi

# Execution-state flags exported for local scripts to avoid re-running tools.
# Use := to preserve a value already exported by the calling script (e.g. the
# local hook pre-sets this to 1 before invoking the global hook so that sqlfluff
# runs exactly once — in the local hook — rather than in both).
: "${SQLFLUFF_EXECUTED:=0}"
export SQLFLUFF_EXECUTED

# ── Installation freshness check (always-on) ─────────────────────────────────
# If a .env in the hooks root records a SHA=<value>, compare it against the
# published SHA at the canonical HTTPS URL.  The fetched SHA is cached for one
# hour under $XDG_CACHE_HOME to avoid a network round-trip on every commit.
# Silently skipped when curl is absent or the URL is unreachable.  Dies if the
# installed SHA is stale.
# Also skipped when running as an AI agent inside any container — the
# container image is fixed at build time and cannot self-update.
if is_ai_agent && is_container; then
    : # skip freshness check
elif [ -f "$HOOKS_REPO_DIR/.env" ] && has_cmd curl; then
    _ENV_SHA=$(grep '^SHA=' "$HOOKS_REPO_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '[:space:]')
    if [ -n "$_ENV_SHA" ]; then
        _CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/pre-commit"
        _CACHE_FILE="$_CACHE_DIR/remote-sha"
        _REMOTE_SHA=""
        if [ -n "$(find "$_CACHE_FILE" -mmin -60 2>/dev/null)" ]; then
            _REMOTE_SHA=$(head -1 "$_CACHE_FILE" 2>/dev/null | tr -d '[:space:]' || true)
        fi
        if [ -z "$_REMOTE_SHA" ]; then
            _REMOTE_SHA=$(curl -sf --connect-timeout 3 --max-time 5 \
                "https://pre-commit.markridgwell.com/sha.txt" 2>/dev/null \
                | head -1 | tr -d '[:space:]' || true)
            printf '%s' "$_REMOTE_SHA" | grep -qE '^[0-9a-fA-F]{7,40}$' || _REMOTE_SHA=""
            if [ -n "$_REMOTE_SHA" ]; then
                mkdir -p "$_CACHE_DIR"
                printf '%s\n' "$_REMOTE_SHA" > "$_CACHE_FILE"
            fi
        fi
        if [ -n "$_REMOTE_SHA" ] && [ "$_REMOTE_SHA" != "$_ENV_SHA" ]; then
            die_blocked "Hooks installation is out of date (installed: ${_ENV_SHA}, latest: ${_REMOTE_SHA})"
        fi
    fi
fi

# ── Mid-commit-only guards (skipped entirely in all-files mode) ──────────────

if [ "$MODE" = "commit" ]; then
    info "Checking branch..."
    CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
    case "$CURRENT_BRANCH" in
        main|master)
            if is_ai_agent; then
                die "Prohibited from committing to ${CURRENT_BRANCH}.  Did you read the .ai-instructions?"
            else
                die "direct commits to ${CURRENT_BRANCH} are not permitted — use a branch and open a pull request"
            fi
            ;;
    esac

    info "Checking git identity..."
    sh "$SCRIPTS_DIR/check-identity" || die_blocked "git identity check"

    info "Checking for merge commits..."
    sh "$SCRIPTS_DIR/check-merge-commits" || die "merge commit detected"
fi

info "Checking for ignored files..."
sh "$SCRIPTS_DIR/check-ignored-files" || die "ignored files found in tracking"

# ── 1. Auto-fixers (normalise content before linting) ────────────────────────

sh "$SCRIPTS_DIR/clean-package-lock-registry" \
    || die "clean-package-lock-registry"

# ── 2. Linters via pre-commit ─────────────────────────────────────────────────
# Use the project's own config if it has one; otherwise run the global linting
# config bundled with these hooks.
if [ "$HAS_PRECOMMIT" -eq 1 ]; then
    REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    PRECOMMIT_MODE_ARG=""
    [ "$MODE" = "all-files" ] && PRECOMMIT_MODE_ARG="--all-files"
    if [ -f "$REPO_ROOT/.pre-commit-config.yaml" ]; then
        info "Running project pre-commit hooks..."
        # shellcheck disable=SC2086  # PRECOMMIT_MODE_ARG is a single flag or empty; word-splitting is intentional.
        pre-commit run $PRECOMMIT_MODE_ARG || die "pre-commit (project config)"
    else
        info "Running global linters (pre-commit)..."
        # shellcheck disable=SC2086  # PRECOMMIT_MODE_ARG is a single flag or empty; word-splitting is intentional.
        pre-commit run --config "$REPO_DIR/.pre-commit-config.yaml" $PRECOMMIT_MODE_ARG \
            || die "pre-commit (global linters)"
    fi
fi

# ── 3. Changelog: lint CHANGELOG.md if changed ───────────────────────────────
CHANGELOG_CHANGES=$(echo "$CHECK_FILES" | grep -E '(^|/)CHANGELOG\.md$' | head -1)
if [ -n "$CHANGELOG_CHANGES" ] && [ "$HAS_DOTNET" -eq 1 ]; then
    info "Detected CHANGELOG.md changes — running changelog lint..."
    sh "$SCRIPTS_DIR/check-changelog" || die "changelog lint"
fi

# ── 4. .NET: format check + build + test if source/project file changes ──────
DOTNET_CHANGES=$(echo "$CHECK_FILES" | grep -E '\.(cs|csproj|sln|slnx|props|targets|globalconfig|ruleset)$' | head -1)
if [ -n "$DOTNET_CHANGES" ] && [ "$HAS_DOTNET" -eq 1 ]; then
    info "Detected .NET changes — running buildcheck..."
    sh "$SCRIPTS_DIR/buildcheck" || die "dotnet buildcheck"
    info "Detected .NET changes — running formatter fix..."
    sh "$SCRIPTS_DIR/run-formatter" || die "cscleanup formatter"
    info "Detected .NET changes — running buildtest..."
    sh "$SCRIPTS_DIR/buildtest" || die "dotnet buildtest"
fi

# ── 5. NPM: run tests if TypeScript/JS changes ───────────────────────────────
TS_CHANGES=$(echo "$CHECK_FILES" | grep -E '\.(ts|tsx|js|jsx)$' | head -1)
if [ -n "$TS_CHANGES" ] && [ -f "$REPO_ROOT/package.json" ] && [ "$HAS_NPM" -eq 1 ]; then
    info "Detected TypeScript/JS changes — running npm tests..."
    if grep -q '"test:noe2e"' "$REPO_ROOT/package.json"; then
        npm run test:noe2e || die "npm run test:noe2e"
    else
        npm test || die "npm test"
    fi
fi

# ── 6. SQL: tsqllint + sqlfluff if .sql changes ──────────────────────────────
SQL_CHANGES=$(echo "$CHECK_FILES" | grep -E '\.sql$' | head -1)
if [ -n "$SQL_CHANGES" ]; then
    if [ "$HAS_DOTNET" -eq 1 ]; then
        dotnet_tool_installed tsqllint TSQLLint || die_blocked "tsqllint dotnet tool is not installed"
        info "Detected SQL changes — running dotnet tsqllint..."
        DOTNET_ROLL_FORWARD=Major dotnet tsqllint . || die "dotnet tsqllint"
    fi
    if [ "$HAS_SQLFLUFF" -eq 1 ] && [ "${SQLFLUFF_EXECUTED:-0}" != "1" ]; then
        info "Detected SQL changes — running sqlfluff fix..."
        sqlfluff fix . || die "sqlfluff fix"
        SQLFLUFF_FIXED=$(git diff --name-only | grep -E '\.sql$' || true)
        if [ -n "$SQLFLUFF_FIXED" ]; then
            info "Staging files modified by sqlfluff fix..."
            echo "$SQLFLUFF_FIXED" | xargs git add --
        fi
        info "Detected SQL changes — running sqlfluff lint..."
        sqlfluff lint . || die "sqlfluff lint"
        export SQLFLUFF_EXECUTED=1
    fi
fi

# ── 7. CloudFormation: cfn-lint on changed templates ─────────────────────────
if [ "$HAS_CFNLINT" -eq 1 ]; then
    CFN_FILES=$(echo "$CHECK_FILES" | grep -E '\.(yaml|yml|json|template)$' \
        | while read -r f; do
            grep -q "AWSTemplateFormatVersion" "$f" 2>/dev/null && echo "$f"
          done)
    if [ -n "$CFN_FILES" ]; then
        info "Detected CloudFormation changes — running cfn-lint..."
        printf '%s\n' "$CFN_FILES" | xargs cfn-lint --include-checks I --template || die "cfn-lint"
    fi
fi

info "All checks passed."
exit 0
