#!/bin/sh
# Global pre-push hook — blocks direct pushes to main/master.
# Installed via: git config --global core.hooksPath /path/to/hooks

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by git and therefore by this hook.
# Source: https://code.claude.com/docs/en/env-vars
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            if is_ai_agent; then
                echo "error: Prohibited from pushing to ${remote_ref}.  Did you read the .ai-instructions?" >&2
            else
                echo "error: direct pushes to ${remote_ref} are not permitted." >&2
                echo "       Open a pull request instead." >&2
            fi
            exit 1
            ;;
    esac
done

exit 0
