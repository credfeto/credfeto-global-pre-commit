#!/bin/sh
# Global pre-push hook — blocks direct pushes to main/master.
# Installed via: git config --global core.hooksPath /path/to/hooks

while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            echo "error: direct pushes to ${remote_ref} are not permitted." >&2
            echo "       Open a pull request instead." >&2
            exit 1
            ;;
    esac
done

exit 0
