#!/bin/sh
# Install global git pre-commit hooks from this repo.
# Sets core.hooksPath globally so every repo on this machine uses these hooks.
# Run once after cloning; re-run after pulling updates.
# Pass --system to install for all users (requires sudo for git config --system).

set -e

SYSTEM_INSTALL=false
for _arg in "$@"; do
    case "$_arg" in
        --system) SYSTEM_INSTALL=true ;;
        *) printf 'Unknown argument: %s\n' "$_arg" >&2; exit 1 ;;
    esac
done

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOKS_DIR="$REPO_DIR/src/hooks"
SCRIPTS_DIR="$REPO_DIR/src/scripts"

# ── Make everything executable ────────────────────────────────────────────────
chmod +x \
    "$HOOKS_DIR/pre-commit" \
    "$HOOKS_DIR/pre-push" \
    "$SCRIPTS_DIR/buildtest" \
    "$SCRIPTS_DIR/benchmark-test-filter" \
    "$SCRIPTS_DIR/buildcheck" \
    "$SCRIPTS_DIR/run-formatter" \
    "$SCRIPTS_DIR/check-changelog" \
    "$SCRIPTS_DIR/check-ignored-files" \
    "$SCRIPTS_DIR/check-merge-commits" \
    "$SCRIPTS_DIR/clean-package-lock-registry" \
    "$SCRIPTS_DIR/run-eslint" \
    "$SCRIPTS_DIR/run-stylelint" \
    "$SCRIPTS_DIR/run-psscriptanalyzer" \
    "$SCRIPTS_DIR/run-bats" \
    "$REPO_DIR/check-setup" \
    "$REPO_DIR/acceptance-test" \
    "$REPO_DIR/install-deps-arch" \
    "$REPO_DIR/install-deps-debian"

# ── Install platform dependencies ─────────────────────────────────────────────
distro_family() {
    [ -f /etc/os-release ] || return 0
    _id=$(grep '^ID=' /etc/os-release | cut -d= -f2- | tr -d '"')
    _like=$(grep '^ID_LIKE=' /etc/os-release | cut -d= -f2- | tr -d '"')
    case "$_id $_like" in
        *arch*)            printf 'arch' ;;
        *debian*|*ubuntu*) printf 'debian' ;;
    esac
}

DISTRO=$(distro_family)
case "$DISTRO" in
    arch)
        echo "Detected Arch-based Linux — running install-deps-arch..."
        "$REPO_DIR/install-deps-arch"
        ;;
    debian)
        echo "Detected Debian-based Linux — running install-deps-debian..."
        "$REPO_DIR/install-deps-debian"
        ;;
    *)
        echo "Platform not recognised — skipping dependency install."
        echo "Run ./install-deps-arch or ./install-deps-debian manually."
        ;;
esac

# ── Register with git ────────────────────────────────────────────────────────
if $SYSTEM_INSTALL; then
    sudo git config --system core.hooksPath "$HOOKS_DIR"
else
    git config --global core.hooksPath "$HOOKS_DIR"
fi

# ── Symlink system-hook wrappers onto PATH ────────────────────────────────────
# These are called by pre-commit's local system hooks.
mkdir -p "$HOME/.local/bin"
ln -sf "$SCRIPTS_DIR/run-eslint"           "$HOME/.local/bin/run-eslint"
ln -sf "$SCRIPTS_DIR/run-stylelint"        "$HOME/.local/bin/run-stylelint"
ln -sf "$SCRIPTS_DIR/run-psscriptanalyzer" "$HOME/.local/bin/run-psscriptanalyzer"
ln -sf "$SCRIPTS_DIR/run-bats"             "$HOME/.local/bin/run-bats"

# Go tools are installed to $GOPATH/bin which may not be on PATH — symlink them.
if command -v go > /dev/null 2>&1; then
    _gobin="$(go env GOPATH)/bin"
    [ -f "$_gobin/composite-action-lint" ] && \
        ln -sf "$_gobin/composite-action-lint" "$HOME/.local/bin/composite-action-lint"
fi

# ── Report setup status ───────────────────────────────────────────────────────
# Validates the pre-commit config and reports which checks/tools are available.
# Exits non-zero (aborting this install under `set -e`) if the config is invalid
# or any required tool is missing.
if $SYSTEM_INSTALL; then
    "$REPO_DIR/check-setup" --system
else
    "$REPO_DIR/check-setup"
fi
