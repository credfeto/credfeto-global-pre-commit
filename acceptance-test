#!/bin/sh
# Entry point for the acceptance test suite.
# Delegates to bats; see test/*.bats for the individual tests.

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOK="${REPO_DIR}/src/hooks/pre-commit"

die() {
    printf '\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

[ -x "${HOOK}" ] || die "hook not found or not executable: ${HOOK}"
command -v git > /dev/null 2>&1 || die "git is not installed"
command -v bats > /dev/null 2>&1 || die "bats is not installed — run ./install-deps-debian or ./install-deps-arch"

exec bats --print-output-on-failure --recursive "${REPO_DIR}/test"
