# ── Helpers for freshness tests ───────────────────────────────────────────────
# All freshness tests place $REPO_DIR/.env temporarily. The global cleanup trap
# removes it on exit/interrupt; each test also removes it explicitly after the
# assert so later tests start with a clean state.

# Run the hook in the given repo with a custom PATH and XDG_CACHE_HOME.
# run_hook_env <repo> <path> <xdg_cache_home>
run_hook_env() {
    _RH_REPO="$1"
    _RH_PATH="$2"
    _RH_CACHE="$3"
    HOOK_OUTPUT=$(mktemp)
    ( cd "$_RH_REPO" && unset CLAUDECODE && env PATH="$_RH_PATH" XDG_CACHE_HOME="$_RH_CACHE" sh "$HOOK" ) > "$HOOK_OUTPUT" 2>&1
    return $?
}

