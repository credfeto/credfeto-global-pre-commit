        return
    fi
    T=$(make_repo "feature/broken-js-test")
    printf '%s' "$ESLINT_PRECOMMIT_CONFIG" > "$T/.pre-commit-config.yaml"
    # Minimal flat config enabling no-unused-vars as an error.
    printf 'module.exports = [{ rules: { "no-unused-vars": "error" } }];\n' > "$T/eslint.config.cjs"
    # No-op test script so the hook's npm-test step does not fail independently.
    printf '{"scripts":{"test":"true"}}' > "$T/package.json"
    # An unused variable reliably triggers no-unused-vars.
    printf 'var unused = 1;\n' > "$T/bad.js"
    git -C "$T" add .pre-commit-config.yaml bad.js
    run_hook "$T"; RC=$?
    destroy_repo "$T"
    assert_exit "broken .js (unused variable) → rejected" 1 "$RC"
}

