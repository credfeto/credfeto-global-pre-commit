test_broken_playbook_rejected() {
    if ! command -v ansible-lint > /dev/null 2>&1; then
        info "SKIP  broken playbook → rejected (ansible-lint not installed)"
        return
    fi
    if ! command -v pre-commit > /dev/null 2>&1; then
        info "SKIP  broken playbook → rejected (pre-commit not installed)"
        return
    fi
    _ANSIBLE_PROBE_DIR=$(mktemp -d)
    _ANSIBLE_PROBE_OUT=$(ansible-lint --nocolor "$_ANSIBLE_PROBE_DIR" 2>&1 || true)
    rm -rf "$_ANSIBLE_PROBE_DIR"
    if printf '%s' "$_ANSIBLE_PROBE_OUT" | grep -qi "do not match\|broken execution"; then
        info "SKIP  broken playbook → rejected (ansible-lint environment broken: version mismatch)"
        return
    fi
    T=$(make_repo "feature/broken-playbook-test")
    printf '%s' "$ANSIBLELINT_PRECOMMIT_CONFIG" > "$T/.pre-commit-config.yaml"
    # Using 'yes' for a boolean value triggers the yaml[truthy] rule, which
    # ansible-lint enforces by default across all profiles.
    printf '%s\n' '---' '- name: Broken playbook' '  hosts: localhost' '  gather_facts: yes' '  tasks:' '    - name: Hello world' '      ansible.builtin.debug:' '        msg: Hello' > "$T/broken.yml"
    git -C "$T" add .pre-commit-config.yaml broken.yml
    run_hook "$T"; RC=$?
    destroy_repo "$T"
    assert_exit "broken playbook (yaml[truthy] violation) → rejected" 1 "$RC"
}

