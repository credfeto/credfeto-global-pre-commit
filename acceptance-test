    run_hook_env "$T" "$FAKE_BIN:$TEST_PATH" "$FAKE_CACHE"; RC=$?
    destroy_repo "$T"
    rm -rf "$FAKE_BIN" "$FAKE_CACHE"
    rm -f "$REPO_DIR/.env"
    assert_exit ".env SHA matches published SHA → passes" 0 "$RC"
}

