# Pre-commit config snippet used by the two dotenv tests below.
# Mirrors the global config entry but scoped to dotenv-linter only so no
# other linter can interfere with the result.
DOTENV_PRECOMMIT_CONFIG='repos:
  - repo: local
    hooks:
      - id: dotenv-linter
        name: dotenv-linter
        entry: dotenv-linter check
        language: system
        files: (^|/)\.env(\.[^/]+)?$
'

# Pre-commit config snippet used by the two xmllint tests below.
# Scoped to xmllint only so no other linter can interfere with the result.
XMLLINT_PRECOMMIT_CONFIG='repos:
  - repo: local
    hooks:
      - id: xmllint
        name: xmllint
        entry: xmllint
        args: [--noout]
        language: system
        types: [xml]
'

# Pre-commit config snippet used by the two PSScriptAnalyzer tests below.
# Uses run-psscriptanalyzer only so no other linter can interfere with the result.
PSSCRIPTANALYZER_PRECOMMIT_CONFIG="repos:
  - repo: local
    hooks:
      - id: run-psscriptanalyzer
        name: run-psscriptanalyzer
        entry: $REPO_DIR/src/scripts/run-psscriptanalyzer
        language: system
        files: \.(ps1|psm1|psd1)\$
"

# Pre-commit config snippet used by the two eslint tests below.
# Uses run-eslint (full path) so no other linter can interfere with the result.
ESLINT_PRECOMMIT_CONFIG="repos:
  - repo: local
    hooks:
      - id: eslint
        name: eslint
        entry: $REPO_DIR/src/scripts/run-eslint
        language: system
        files: \.(ts|tsx|js|jsx)\$
"

# Pre-commit config snippet used by the two actionlint tests below.
# Scoped to actionlint only so no other linter can interfere with the result.
ACTIONLINT_PRECOMMIT_CONFIG='repos:
  - repo: local
    hooks:
      - id: actionlint
        name: actionlint
        entry: actionlint
        language: system
        files: ^\.github/workflows/.*\.(yml|yaml)$
'

# Pre-commit config snippet used by the two stylelint tests below.
# Uses run-stylelint (full path) so no other linter can interfere with the result.
STYLELINT_PRECOMMIT_CONFIG="repos:
  - repo: local
    hooks:
      - id: stylelint
        name: stylelint
        entry: $REPO_DIR/src/scripts/run-stylelint
        language: system
        files: \\.css\$
"

# Pre-commit config snippet used by the two ansible-lint tests below.
# Scoped to ansible-lint only so no other linter can interfere with the result.
ANSIBLELINT_PRECOMMIT_CONFIG='repos:
  - repo: local
    hooks:
      - id: ansible-lint
        name: ansible-lint
        entry: ansible-lint -v --force-color --exclude .github
        language: system
        pass_filenames: false
        always_run: true
'

# Pre-commit config snippet used by the two composite-action-lint tests below.
