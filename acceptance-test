#!/bin/sh
# Acceptance tests for the global pre-commit hook orchestrator.
# Each test creates an isolated git repository and removes it on completion.

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOKS_DIR="$REPO_DIR/src/hooks"
HOOK="$HOOKS_DIR/pre-commit"

PASS=0
FAIL=0
HOOK_OUTPUT=""

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

fail_msg() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

[ -x "$HOOK" ] || die "hook not found or not executable: $HOOK"
command -v git > /dev/null 2>&1 || die "git is not installed"

# ── PATH sanitisation ─────────────────────────────────────────────────────────
# The hook enforces that dotnet (if present) must resolve to
# /usr/share/dotnet/dotnet.  On machines where dotnet lives elsewhere
# (e.g. /usr/local/bin/dotnet) we strip it from the PATH used by general
# tests so those tests are not aborted by the environment-sanity check.
# Tests that specifically exercise the dotnet-path validation use their own
# controlled PATH/HOME and do not go through run_hook.
_EXPECTED_DOTNET="/usr/share/dotnet/dotnet"
_ACTUAL_DOTNET_BIN=$(command -v dotnet 2>/dev/null || true)
_ACTUAL_DOTNET_REAL=$(readlink -f "$_ACTUAL_DOTNET_BIN" 2>/dev/null || echo "$_ACTUAL_DOTNET_BIN")
if [ -n "$_ACTUAL_DOTNET_BIN" ] && [ "$_ACTUAL_DOTNET_REAL" != "$_EXPECTED_DOTNET" ]; then
    _DOTNET_DIR=$(dirname "$_ACTUAL_DOTNET_BIN")
    TEST_PATH=$(printf '%s' "$PATH" | tr ':' '\n' | grep -Fxv "$_DOTNET_DIR" | tr '\n' ':' | sed 's/:$//')
else
    TEST_PATH="$PATH"
fi

# Create an isolated git repo on the given branch (default: feature/acceptance-test).
# Prints the repo path; stores it in CURRENT_REPO for cleanup.
make_repo() {
    BRANCH="${1:-feature/acceptance-test}"
    T=$(mktemp -d)
    CURRENT_REPO="$T"
    git -C "$T" init --quiet
    git -C "$T" symbolic-ref HEAD "refs/heads/$BRANCH"
    git -C "$T" config user.email "test@example.com"
    git -C "$T" config user.name "Test User"
    git -C "$T" config core.hooksPath "$HOOKS_DIR"
    printf '%s' "$T"
}

destroy_repo() {
    rm -rf "$1"
    CURRENT_REPO=""
}

# Safety net: remove any repo or output file that survives an interrupted test.
CURRENT_REPO=""
cleanup() {
    [ -n "$CURRENT_REPO" ] && rm -rf "$CURRENT_REPO"
    rm -f "$HOOK_OUTPUT"
    rm -f "$REPO_DIR/.env"
}
trap cleanup EXIT INT TERM

# Run the hook in the given repo directory using TEST_PATH (dotnet stripped
# when not at the expected location).  Exit code is returned; combined
# stdout+stderr is stored in $HOOK_OUTPUT.
run_hook() {
    HOOK_OUTPUT=$(mktemp)
    ( cd "$1" && PATH="$TEST_PATH" && unset CLAUDECODE && sh "$HOOK" ) > "$HOOK_OUTPUT" 2>&1
    return $?
}

# Record a test result and clean up the captured output.
# assert_exit <name> <expected-exit> <actual-exit>
assert_exit() {
    NAME="$1"
    EXPECTED="$2"
    ACTUAL="$3"
    if [ "$ACTUAL" = "$EXPECTED" ]; then
        PASS=$((PASS + 1))
        success "PASS  $NAME"
    else
        FAIL=$((FAIL + 1))
        fail_msg "FAIL  $NAME (expected exit $EXPECTED, got $ACTUAL)"
        if [ -f "$HOOK_OUTPUT" ]; then
            cat "$HOOK_OUTPUT" >&2
        fi
    fi
    rm -f "$HOOK_OUTPUT"
    HOOK_OUTPUT=""
}

# ── Tests ─────────────────────────────────────────────────────────────────────

test_nothing_staged_fails() {
    T=$(make_repo)
    run_hook "$T"; RC=$?
    destroy_repo "$T"
    assert_exit "nothing staged → exits non-zero" 1 "$RC"
}

test_commit_on_main_rejected() {
    T=$(make_repo "main")
    printf 'hello\n' > "$T/file.txt"
    git -C "$T" add file.txt
    run_hook "$T"; RC=$?
    destroy_repo "$T"
    assert_exit "commit on main branch → rejected" 1 "$RC"
}

