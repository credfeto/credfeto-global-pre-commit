test_freshness_matching_sha_passes() {
    # .env SHA matches the published SHA → hook passes.
    FAKE_BIN=$(mktemp -d)
    printf '#!/bin/sh\nprintf "abcdef1234567890"\n' > "$FAKE_BIN/curl"
    chmod +x "$FAKE_BIN/curl"
    FAKE_CACHE=$(mktemp -d)
    printf 'SHA=abcdef1234567890\n' > "$REPO_DIR/.env"
    T=$(make_repo "feature/freshness-match-test")
    printf 'repos: []\n' > "$T/.pre-commit-config.yaml"
    printf '# test\n' > "$T/README.md"
