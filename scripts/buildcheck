#! /bin/sh
# Sourced from https://github.com/credfeto/scripts/blob/main/development/buildcheck

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Returns 0 if $1 (command name) or $2 (package ID) is found in local or global dotnet tool list.
dotnet_tool_installed() {
    _list=$(dotnet tool list 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    _list=$(dotnet tool list --global 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    return 1
}

dotnet_tool_installed buildcheck buildcheck || die "buildcheck dotnet tool is not installed — install with: dotnet tool install --local buildcheck"

SOLUTION=$(find "$PWD" -type f -iname "*.sln" | head -1)
[ -z "$SOLUTION" ] && SOLUTION=$(find "$PWD" -type f -iname "*.slnx" | head -1)
[ -z "$SOLUTION" ] && { info "No solution file found — skipping"; exit 0; }

dotnet buildcheck -Solution "$SOLUTION" -WarningAsErrors true -PreReleaseBuild true || die "Check failed"
