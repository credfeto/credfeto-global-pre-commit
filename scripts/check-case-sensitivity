#!/bin/sh
# Fails if any two tracked files differ only by case.
# Equivalent of funfair-server-template check-no-case-sensitivity-conflicts action.

DUPES=$(git ls-files | awk '{print tolower($0)}' | sort | uniq -d)

if [ -z "$DUPES" ]; then
    exit 0
fi

echo "Case sensitivity conflicts found:" >&2
while IFS= read -r lower; do
    git ls-files | awk -v l="$lower" 'tolower($0)==l {print "  " $0}' >&2
done << EOF
$DUPES
EOF
exit 1
