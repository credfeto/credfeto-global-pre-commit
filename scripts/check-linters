#!/bin/sh
# Mirrors the super-linter VALIDATE_* config, running only on staged files
# (equivalent to VALIDATE_ALL_CODEBASE: false).
# Each linter is skipped silently if the tool is not installed.
#
# Already handled in the main pre-commit hook (not duplicated here):
#   VALIDATE_SQLFLUFF       → scripts/check-secrets (sqlfluff lint)
#   VALIDATE_CLOUDFORMATION → cfn-lint block in pre-commit

REPO_ROOT=$(git rev-parse --show-toplevel)
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

[ -z "$STAGED" ] && exit 0

fail() { echo "error: $*" >&2; exit 1; }
has()  { command -v "$1" > /dev/null 2>&1; }

# Returns staged files whose paths match the given ERE pattern
files() { printf '%s\n' "$STAGED" | grep -E "$1" 2>/dev/null || true; }

# ── VALIDATE_ANSIBLE ─────────────────────────────────────────────────────────
# Detect YAML files that look like Ansible playbooks (contain a 'hosts:' key)
if has ansible-lint; then
    ANSIBLE=$(files '\.(yml|yaml)$' | while read -r f; do
        grep -qE '^\s*-?\s*hosts:' "$f" 2>/dev/null && echo "$f"
    done)
    if [ -n "$ANSIBLE" ]; then
        echo "$ANSIBLE" | tr '\n' '\0' | xargs -0 ansible-lint \
            || fail "VALIDATE_ANSIBLE: ansible-lint"
    fi
fi

# ── VALIDATE_BASH ─────────────────────────────────────────────────────────────
if has shellcheck; then
    BASH=$(files '\.(sh|bash)$')
    # Also catch extensionless files with a shell shebang
    SHEBANG=$(files '' | while read -r f; do
        [ -f "$f" ] && head -1 "$f" 2>/dev/null | grep -qE '^#!.*\b(sh|bash)\b' && echo "$f"
    done)
    ALL_BASH=$(printf '%s\n%s' "$BASH" "$SHEBANG" | sort -u | grep -v '^$')
    if [ -n "$ALL_BASH" ]; then
        echo "$ALL_BASH" | tr '\n' '\0' | xargs -0 shellcheck \
            || fail "VALIDATE_BASH: shellcheck"
    fi
fi

# ── VALIDATE_CSS ──────────────────────────────────────────────────────────────
if has stylelint; then
    CSS=$(files '\.css$')
    if [ -n "$CSS" ]; then
        echo "$CSS" | tr '\n' '\0' | xargs -0 stylelint \
            || fail "VALIDATE_CSS: stylelint"
    fi
fi

# ── VALIDATE_ENV ──────────────────────────────────────────────────────────────
if has dotenv-linter; then
    ENV=$(files '(^|/)\.env(\.[^/]+)?$')
    if [ -n "$ENV" ]; then
        echo "$ENV" | tr '\n' '\0' | xargs -0 dotenv-linter \
            || fail "VALIDATE_ENV: dotenv-linter"
    fi
fi

# ── VALIDATE_DOCKERFILE + VALIDATE_DOCKERFILE_HADOLINT ───────────────────────
if has hadolint; then
    DOCKER=$(files '(^|/)Dockerfile[^/]*$')
    if [ -n "$DOCKER" ]; then
        echo "$DOCKER" | tr '\n' '\0' | xargs -0 hadolint \
            || fail "VALIDATE_DOCKERFILE: hadolint"
    fi
fi

# ── VALIDATE_GITHUB_ACTIONS ───────────────────────────────────────────────────
if has actionlint; then
    GHA=$(files '^\.github/(workflows|actions)/.*\.(yml|yaml)$')
    if [ -n "$GHA" ]; then
        echo "$GHA" | tr '\n' '\0' | xargs -0 actionlint \
            || fail "VALIDATE_GITHUB_ACTIONS: actionlint"
    fi
fi

# ── VALIDATE_JSON ─────────────────────────────────────────────────────────────
if has jq; then
    JSON=$(files '\.json$')
    if [ -n "$JSON" ]; then
        FAILED=0
        while IFS= read -r f; do
            jq . "$f" > /dev/null 2>&1 || { echo "invalid JSON: $f" >&2; FAILED=1; }
        done << EOF
$JSON
EOF
        [ "$FAILED" -eq 0 ] || fail "VALIDATE_JSON: jq"
    fi
fi

# ── VALIDATE_MD ───────────────────────────────────────────────────────────────
if has markdownlint; then
    MD=$(files '\.md$')
    if [ -n "$MD" ]; then
        echo "$MD" | tr '\n' '\0' | xargs -0 markdownlint \
            || fail "VALIDATE_MD: markdownlint"
    fi
fi

# ── VALIDATE_POWERSHELL ───────────────────────────────────────────────────────
if has pwsh; then
    PS=$(files '\.(ps1|psm1|psd1)$')
    if [ -n "$PS" ]; then
        FAILED=0
        while IFS= read -r f; do
            pwsh -NoProfile -NonInteractive -Command \
                "Import-Module PSScriptAnalyzer -ErrorAction Stop
                 \$r = Invoke-ScriptAnalyzer -Path '$REPO_ROOT/$f' -Severity Error,Warning
                 if (\$r) { \$r | Format-Table -AutoSize; exit 1 }" 2>&1 \
                || { echo "PSScriptAnalyzer failed: $f" >&2; FAILED=1; }
        done << EOF
$PS
EOF
        [ "$FAILED" -eq 0 ] || fail "VALIDATE_POWERSHELL: PSScriptAnalyzer"
    fi
fi

# ── VALIDATE_PYTHON + VALIDATE_PYTHON_PYLINT ─────────────────────────────────
PY=$(files '\.py$')
if [ -n "$PY" ]; then
    if has flake8; then
        echo "$PY" | tr '\n' '\0' | xargs -0 flake8 \
            || fail "VALIDATE_PYTHON: flake8"
    fi
    if has pylint; then
        echo "$PY" | tr '\n' '\0' | xargs -0 pylint \
            || fail "VALIDATE_PYTHON_PYLINT: pylint"
    fi
fi

# ── VALIDATE_TYPESCRIPT_ES ────────────────────────────────────────────────────
TS=$(files '\.(ts|tsx)$')
if [ -n "$TS" ] && [ -f "$REPO_ROOT/package.json" ]; then
    ESLINT=""
    [ -f "$REPO_ROOT/node_modules/.bin/eslint" ] && ESLINT="$REPO_ROOT/node_modules/.bin/eslint"
    has eslint && ESLINT="eslint"
    if [ -n "$ESLINT" ]; then
        echo "$TS" | tr '\n' '\0' | xargs -0 "$ESLINT" \
            || fail "VALIDATE_TYPESCRIPT_ES: eslint"
    fi
fi

# ── VALIDATE_XML ──────────────────────────────────────────────────────────────
if has xmllint; then
    XML=$(files '\.xml$')
    if [ -n "$XML" ]; then
        echo "$XML" | tr '\n' '\0' | xargs -0 xmllint --noout \
            || fail "VALIDATE_XML: xmllint"
    fi
fi

# ── VALIDATE_YAML ─────────────────────────────────────────────────────────────
if has yamllint; then
    YAML=$(files '\.(yml|yaml)$')
    if [ -n "$YAML" ]; then
        echo "$YAML" | tr '\n' '\0' | xargs -0 yamllint \
            || fail "VALIDATE_YAML: yamllint"
    fi
fi

exit 0
