#!/bin/sh
# Applies C# formatting using cscleanup (Credfeto.DotNet.Repo.Formatter) on staged .cs files,
# then re-stages any files that were modified.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

if ! command -v cscleanup > /dev/null 2>&1; then
    die "cscleanup not found — install Credfeto.DotNet.Repo.Formatter: dotnet tool install --global Credfeto.DotNet.Repo.Formatter"
fi

REPO_ROOT=$(git rev-parse --show-toplevel)

# Collect staged .cs files only — project/config files are intentionally excluded
CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$')

if [ -z "$CS_FILES" ]; then
    info "No staged .cs files — skipping formatter"
    exit 0
fi

info "Applying cscleanup formatting to staged .cs files..."

# Format each file; die immediately if cscleanup reports an error
while IFS= read -r f; do
    cscleanup "${REPO_ROOT}/${f}" || die "cscleanup format failed on ${f}"
done <<EOF
$CS_FILES
EOF

# Re-stage files so any formatting changes are included in the commit
while IFS= read -r f; do
    git add "${REPO_ROOT}/${f}"
done <<EOF
$CS_FILES
EOF

success "cscleanup formatting applied and staged"
