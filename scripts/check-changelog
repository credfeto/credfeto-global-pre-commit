#!/bin/sh
# Lints staged CHANGELOG.md files using `dotnet changelog --lint`.

TOOL_CMD="changelog"
TOOL_PKG="credfeto.changelog.cmd"

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Returns 0 if $1 (command name) or $2 (package ID) is found in local or global dotnet tool list.
dotnet_tool_installed() {
    _list=$(dotnet tool list 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    _list=$(dotnet tool list --global 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    return 1
}

if ! dotnet_tool_installed "$TOOL_CMD" "$TOOL_PKG"; then
    die "${TOOL_CMD} is not installed — install with: dotnet tool install --local ${TOOL_PKG}"
fi

STAGED_CHANGELOGS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)CHANGELOG\.md$')
[ -z "$STAGED_CHANGELOGS" ] && exit 0

# Lint each staged CHANGELOG.md.
FAILED=0
# shellcheck disable=SC2086
for changelog in $STAGED_CHANGELOGS; do
    [ -f "$changelog" ] || continue
    info "Linting ${changelog}..."
    dotnet changelog --lint -f "$changelog" || FAILED=1
done

[ "$FAILED" -eq 0 ] || die "changelog lint failed"
exit 0
