#!/bin/sh
# Lints staged CHANGELOG.md files using `dotnet changelog --lint`.
# Ensures Credfeto.Changelog.Cmd >= 1.10.194.1792, upgrading in-place if needed.

MIN_VERSION="1.10.194.1792"
TOOL_ID="credfeto.changelog.cmd"

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Returns 0 (true) if version $1 >= version $2.
version_gte() {
    [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -1)" = "$2" ]
}

# Returns 0 if $1 (package ID) is installed as a local or global dotnet tool.
dotnet_tool_installed() {
    dotnet tool list 2>/dev/null | grep -qi "^$1[[:space:]]" && return 0
    dotnet tool list --global 2>/dev/null | grep -qi "^$1[[:space:]]" && return 0
    return 1
}

if ! dotnet_tool_installed "$TOOL_ID"; then
    die "${TOOL_ID} is not installed — install with: dotnet tool install --global ${TOOL_ID}"
fi

STAGED_CHANGELOGS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)CHANGELOG\.md$')
[ -z "$STAGED_CHANGELOGS" ] && exit 0

# Upgrade global install if below the minimum required version.
# Local versions are pinned in the tool manifest — skip version check for those.
GLOBAL_VERSION=$(dotnet tool list --global 2>/dev/null | grep -i "^${TOOL_ID}[[:space:]]" | awk '{print $2}')
if [ -n "$GLOBAL_VERSION" ] && ! version_gte "$GLOBAL_VERSION" "$MIN_VERSION"; then
    info "Upgrading ${TOOL_ID} from ${GLOBAL_VERSION} to >= ${MIN_VERSION}..."
    dotnet tool update --global "$TOOL_ID" \
        || die "Failed to upgrade ${TOOL_ID}"
fi

# Lint each staged CHANGELOG.md.
FAILED=0
# shellcheck disable=SC2086
for changelog in $STAGED_CHANGELOGS; do
    [ -f "$changelog" ] || continue
    info "Linting ${changelog}..."
    dotnet changelog --lint -f "$changelog" || FAILED=1
done

[ "$FAILED" -eq 0 ] || die "changelog lint failed"
exit 0
