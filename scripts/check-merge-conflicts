#!/bin/sh
# Fails if merge conflict markers are found in staged files.
# Equivalent of funfair-server-template check-no-merge-conflicts action.

CONFLICTS=$(git diff --cached --name-only --diff-filter=ACM \
    | xargs grep -l -E '^(<{7}|>{7})' 2>/dev/null)

if [ -n "$CONFLICTS" ]; then
    echo "Merge conflict markers found in:" >&2
    echo "$CONFLICTS" | sed 's/^/  /' >&2
    exit 1
fi

exit 0
