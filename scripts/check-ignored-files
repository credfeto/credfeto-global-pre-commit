#!/bin/sh
# Fails if any tracked file is matched by .gitignore rules.
# Equivalent of funfair-server-template check-no-ignored-files action.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

# When running inside the hooks repo itself, .pre-commit-config.yaml is
# intentionally tracked despite appearing in .gitignore (it is the global
# config shipped with this repo).  Whitelist it only in this case.
HOOKS_REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CURRENT_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

TRACKED=$(git ls-files | grep -v 'server\.pfx' | grep -v '\.gitignore')
if [ "$CURRENT_REPO_ROOT" = "$HOOKS_REPO_DIR" ]; then
    TRACKED=$(echo "$TRACKED" | grep -v '\.pre-commit-config\.yaml')
fi

if [ -z "$TRACKED" ]; then
    exit 0
fi

IGNORED=$(echo "$TRACKED" | git check-ignore --stdin --no-index 2>/dev/null)
STATUS=$?

# git check-ignore exits 1 when no files matched — that's a pass
if [ $STATUS -eq 1 ] || [ -z "$IGNORED" ]; then
    exit 0
fi

if [ $STATUS -ne 0 ]; then
    die "git check-ignore failed"
fi

printf '\n\033[31m✗\033[0m %s\n' "Ignored files found in tracking:" >&2
echo "$IGNORED" | sed 's/^/  /' | sort -u >&2
exit 1
