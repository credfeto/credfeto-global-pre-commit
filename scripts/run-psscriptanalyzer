#!/bin/sh
# Wrapper for PSScriptAnalyzer — accepts one or more PowerShell file paths.
# Called by pre-commit with all staged .ps1/.psm1/.psd1 files as arguments.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

# Returns 0 if $1 (command name) or $2 (package ID) is found in local or global dotnet tool list.
dotnet_tool_installed() {
    _list=$(dotnet tool list 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    _list=$(dotnet tool list --global 2>/dev/null)
    printf '%s\n' "$_list" | grep -qi "[[:space:]]$1$" && return 0
    printf '%s\n' "$_list" | grep -qi "^$2[[:space:]]" && return 0
    return 1
}

dotnet_tool_installed pwsh PowerShell || die "pwsh dotnet tool is not installed — install with: dotnet tool install --local PowerShell"

FAILED=0
for f in "$@"; do
    dotnet pwsh -NoProfile -NonInteractive -Command "
        Import-Module PSScriptAnalyzer -ErrorAction Stop
        \$r = Invoke-ScriptAnalyzer -Path '$f' -Severity Error,Warning
        if (\$r) { \$r | Format-Table -AutoSize; exit 1 }
    " || { printf '\n\033[31m✗\033[0m %s\n' "PSScriptAnalyzer failed: $f" >&2; FAILED=1; }
done
[ "$FAILED" -eq 0 ] || die "PSScriptAnalyzer failed on one or more files"
