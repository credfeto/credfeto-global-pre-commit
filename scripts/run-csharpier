#!/bin/sh
# Checks C# formatting using dotnet csharpier.

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*"
    exit 1
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

REPO_ROOT=$(git rev-parse --show-toplevel)

dotnet csharpier check "$REPO_ROOT" || die "csharpier format check failed — run: dotnet csharpier \"$REPO_ROOT\""

info "csharpier format check passed"
