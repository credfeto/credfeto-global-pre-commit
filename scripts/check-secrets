#!/bin/sh
# Scans staged changes for verified secrets using trufflehog.
# Skipped silently if trufflehog is not on PATH.

if ! command -v trufflehog > /dev/null 2>&1; then
    exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)

# Capture all output; only surface it on failure so normal commits stay quiet.
OUTPUT=$(trufflehog git "file://$REPO_ROOT" \
    --since-commit HEAD \
    --only-verified \
    --no-update \
    --fail 2>&1)
STATUS=$?

# trufflehog exits 183 when secrets are found, 0 for clean.
# Any other code means it crashed (broken install, missing binary, etc.).
if [ $STATUS -eq 183 ]; then
    printf '%s\n' "$OUTPUT" >&2
    echo "error: trufflehog detected verified secrets in staged changes." >&2
    exit 1
elif [ $STATUS -ne 0 ]; then
    printf '%s\n' "$OUTPUT" >&2
    echo "error: trufflehog failed to run (exit $STATUS) — check installation." >&2
    exit 1
fi

exit 0
